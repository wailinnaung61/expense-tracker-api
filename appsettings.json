{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ExpenseTracker;Username=postgres;Password=admin",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=10000,syncTimeout=10000,asyncTimeout=10000,connectRetry=3"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "Amazon": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/expense-tracker-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName", "WithThreadId" ],
    "Properties": {
      "Application": "ExpenseTrackerAPI"
    }
  },
  "AWS": {
    "Region": "us-east-1",
    "AccessKey": "",
    "SecretKey": "",
    "Cognito": {
      "UserPoolId": "",
      "ClientId": "",
      "ClientSecret": "",
      "Authority": "",
      "Domain": "us-east-16k0zo09es",
      "Region": "us-east-1"
    },
    "EventBridge": {
      "EventBusName": "default",
      "Source": "expense-tracker.export"
    },
    "S3": {
      "ExportBucketName": "",
      "PresignedUrlExpiryMinutes": 5
    }
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:8081", "http://localhost:8082" ]
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini"
  },
  "Email": {
    "Enabled": true,
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseSsl": true,
      "Username": "mail.expensetracker.app@gmail.com",
      "Password": "kznioxymotldwoyn",
      "FromAddress": "mail.expensetracker.app@gmail.com",
      "FromName": "Spendio"
    },
    "QuietHours": {
      "StartHour": 22,
      "EndHour": 8
    },
    "Timings": {
      "RecurringDueDaysBefore": [ 7, 3, 1 ],
      "RecurringDueOnDueDate": true,
      "RecurringOverdueDaysAfter": [ 1 ],
      "SavingGoalDeadlineDaysBefore": 7
    },
    "LayoutHtml": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"/><title>Spendio</title></head><body style=\"margin:0;padding:0;background:#F3F4F6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;\"><div style=\"display:none;max-height:0;overflow:hidden;opacity:0;\">{{preheader}}</div><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F3F4F6;padding:32px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#FFFFFF;border-radius:16px;overflow:hidden;border:1px solid #E5E7EB;\"><tr><td style=\"background:linear-gradient(135deg,#0F766E 0%,#115E59 100%);padding:28px 32px;\"><div style=\"font-size:12px;letter-spacing:0.12em;text-transform:uppercase;color:#99F6E4;font-weight:700;\">Spendio</div><div style=\"font-size:20px;color:#FFFFFF;font-weight:700;margin-top:6px;\">Spend smarter. Stay in control.</div></td></tr><tr><td style=\"padding:32px;\">{{content}}</td></tr><tr><td style=\"padding:20px 32px 28px;border-top:1px solid #E5E7EB;background:#F9FAFB;\"><div style=\"font-size:12px;color:#9CA3AF;line-height:1.6;\">You’re receiving this because email alerts are enabled on your account.<br/>Manage preferences anytime in <strong style=\"color:#6B7280;\">Email Sent</strong> settings.</div><div style=\"font-size:11px;color:#D1D5DB;margin-top:12px;\">© Spendio · usespendio.com</div></td></tr></table></td></tr></table></body></html>",
    "Templates": {
      "BUDGET_THRESHOLD_REACHED": {
        "en": {
          "subject": "Budget alert: {categoryName} at {percent}%",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#B45309;\">Budget alert</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">You’re nearing your {categoryName} limit</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">You’ve used <strong style=\"color:#111827;\">{percent}%</strong> of this category’s budget. A little caution now keeps the rest of the month comfortable.</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FFFBEB;border:1px solid #FCD34D;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B45309;font-weight:600;text-transform:uppercase;\">Spent</div><div style=\"font-size:28px;font-weight:800;color:#92400E;padding-top:4px;\">{spent}</div><div style=\"font-size:13px;color:#78716C;padding-top:4px;\">of {allocated} allocated</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#6B7280;\">Category</td><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{categoryName}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">Usage</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{percent}%</td></tr></table></td></tr></table>"
        },
        "ja": {
          "subject": "予算アラート: {categoryName} が {percent}%",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#B45309;\">予算アラート</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{categoryName} の予算に近づいています</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">このカテゴリの予算の <strong style=\"color:#111827;\">{percent}%</strong> を使用しました。残り期間のために少しペースを整えましょう。</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FFFBEB;border:1px solid #FCD34D;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B45309;font-weight:600;\">使用額</div><div style=\"font-size:28px;font-weight:800;color:#92400E;padding-top:4px;\">{spent}</div><div style=\"font-size:13px;color:#78716C;padding-top:4px;\">予算 {allocated}</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#6B7280;\">カテゴリ</td><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{categoryName}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">使用率</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{percent}%</td></tr></table></td></tr></table>"
        },
        "my": {
          "subject": "ဘတ်ဂျက်သတိပေးချက်: {categoryName} {percent}%",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;color:#B45309;\">ဘတ်ဂျက်သတိပေးချက်</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{categoryName} ဘတ်ဂျက်နီးလာပါပြီ</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">ဤအမျိုးအစား၏ ဘတ်ဂျက် <strong style=\"color:#111827;\">{percent}%</strong> သုံးစွဲပြီးပါပြီ။ လ၏ကျန်ရက်များအတွက် ဂရုစိုက်ပါ။</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FFFBEB;border:1px solid #FCD34D;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B45309;font-weight:600;\">သုံးစွဲ</div><div style=\"font-size:28px;font-weight:800;color:#92400E;padding-top:4px;\">{spent}</div><div style=\"font-size:13px;color:#78716C;padding-top:4px;\">ဘတ်ဂျက် {allocated}</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#6B7280;\">အမျိုးအစား</td><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{categoryName}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">ရာခိုင်နှုန်း</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{percent}%</td></tr></table></td></tr></table>"
        }
      },
      "BUDGET_EXCEEDED": {
        "en": {
          "subject": "Budget exceeded: {categoryName}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#B91C1C;\">Over budget</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{categoryName} budget has been exceeded</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">Spending in this category is now above your allocated amount. Review recent expenses or adjust the budget if needed.</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FEF2F2;border:1px solid #FECACA;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B91C1C;font-weight:600;text-transform:uppercase;\">Spent</div><div style=\"font-size:28px;font-weight:800;color:#991B1B;padding-top:4px;\">{spent}</div><div style=\"font-size:13px;color:#78716C;padding-top:4px;\">budget was {allocated}</div></td></tr></table></td></tr></table>"
        },
        "ja": {
          "subject": "予算超過: {categoryName}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;color:#B91C1C;\">予算超過</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{categoryName} の予算を超えました</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">このカテゴリの支出が割当額を超えました。最近の支出を確認するか、予算を見直してください。</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FEF2F2;border:1px solid #FECACA;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B91C1C;font-weight:600;\">使用額</div><div style=\"font-size:28px;font-weight:800;color:#991B1B;padding-top:4px;\">{spent}</div><div style=\"font-size:13px;color:#78716C;padding-top:4px;\">予算 {allocated}</div></td></tr></table></td></tr></table>"
        },
        "my": {
          "subject": "ဘတ်ဂျက်ကျော်လွန်: {categoryName}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;color:#B91C1C;\">ဘတ်ဂျက်ကျော်လွန်</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{categoryName} ဘတ်ဂျက်ကျော်လွန်ပါပြီ</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">ဤအမျိုးအစားအတွက် သတ်မှတ်ဘတ်ဂျက်ထက် ပိုသုံးစွဲနေပါသည်။ မကြာသေးမီ အသုံးစရိတ်များကို စစ်ဆေးပါ။</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FEF2F2;border:1px solid #FECACA;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B91C1C;font-weight:600;\">သုံးစွဲ</div><div style=\"font-size:28px;font-weight:800;color:#991B1B;padding-top:4px;\">{spent}</div><div style=\"font-size:13px;color:#78716C;padding-top:4px;\">ဘတ်ဂျက် {allocated}</div></td></tr></table></td></tr></table>"
        }
      },
      "RECURRING_PAYMENT_DUE": {
        "en": {
          "subject": "Bill due soon: {name}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#0369A1;\">Upcoming bill</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{name} is coming due</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">A reminder so you can prepare payment before the due date.</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F0F9FF;border:1px solid #BAE6FD;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#0369A1;font-weight:600;text-transform:uppercase;\">Amount due</div><div style=\"font-size:28px;font-weight:800;color:#0C4A6E;padding-top:4px;\">{amount}</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#6B7280;\">Bill</td><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{name}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">Due date</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{dueDate}</td></tr></table></td></tr></table>"
        },
        "ja": {
          "subject": "支払い予定: {name}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;color:#0369A1;\">支払い予定</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{name} の支払日が近づいています</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">期日までに支払いの準備ができるようお知らせします。</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F0F9FF;border:1px solid #BAE6FD;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#0369A1;font-weight:600;\">支払額</div><div style=\"font-size:28px;font-weight:800;color:#0C4A6E;padding-top:4px;\">{amount}</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#6B7280;\">項目</td><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{name}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">支払日</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{dueDate}</td></tr></table></td></tr></table>"
        },
        "my": {
          "subject": "ပေးချေရန်နီးပြီ: {name}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;color:#0369A1;\">ပေးချေရန်နီးပြီ</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{name} ပေးချေရမည့်ရက် နီးလာပါပြီ</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">သတ်မှတ်ရက်မတိုင်မီ ပြင်ဆင်နိုင်ရန် သတိပေးချက်ဖြစ်သည်။</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#F0F9FF;border:1px solid #BAE6FD;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#0369A1;font-weight:600;\">ပမာဏ</div><div style=\"font-size:28px;font-weight:800;color:#0C4A6E;padding-top:4px;\">{amount}</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#6B7280;\">အမည်</td><td style=\"padding:12px 0;border-bottom:1px solid #E5E7EB;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{name}</td></tr><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">ပေးရမည့်ရက်</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{dueDate}</td></tr></table></td></tr></table>"
        }
      },
      "RECURRING_PAYMENT_OVERDUE": {
        "en": {
          "subject": "Bill overdue: {name}",
          "bodyHtml": "<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td style=\"font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#B91C1C;\">Overdue</td></tr><tr><td style=\"padding-top:8px;font-size:22px;font-weight:700;color:#111827;line-height:1.3;\">{name} payment is overdue</td></tr><tr><td style=\"padding-top:10px;font-size:15px;color:#4B5563;line-height:1.6;\">This bill has passed its due date. Please pay as soon as you can to avoid further missed counts.</td></tr><tr><td style=\"padding-top:24px;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#FEF2F2;border:1px solid #FECACA;border-radius:12px;\"><tr><td style=\"padding:20px;text-align:center;\"><div style=\"font-size:12px;color:#B91C1C;font-weight:600;text-transform:uppercase;\">Missed</div><div style=\"font-size:28px;font-weight:800;color:#991B1B;padding-top:4px;\">{missedCount}×</div></td></tr></table></td></tr><tr><td style=\"padding-top:20px;\"><table width=\"100%\" style=\"border-collapse:collapse;\"><tr><td style=\"padding:12px 0;font-size:14px;color:#6B7280;\">Bill</td><td style=\"padding:12px 0;font-size:14px;color:#111827;text-align:right;font-weight:600;\">{name}</td></tr></table></td></tr></table>"
        },
        "ja": {
